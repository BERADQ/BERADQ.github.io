.Nav {
  position: fixed;
  display: flex;
  top: 0;
  left: 0;
  height: 100%;
  width: 80px;
  background-color: #1d2020;
  &[data-orientation="vertical"] {
    flex-direction: column;
    align-items: stretch;
    border-right: var(--indicator-width) solid #3d3d3d;
  }
}
.tabs[data-orientation="vertical"] {
  --indicator-width: 3px;
  display: flex;
}
